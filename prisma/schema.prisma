// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Account {
  id         String  @id @default(cuid())
  accountId  String  @unique
  holderName String
  balance    Decimal @default(0.00) @db.Decimal(18, 2)
  version    Int     @default(1)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outgoingTransactions Transaction[] @relation("FromAccountTransactions")
  incomingTransactions Transaction[] @relation("ToAccountTransactions")

  @@index([accountId])
  @@index([holderName])
  @@index([version])
}

model Transaction {
  id     String            @id @default(cuid())
  txId   String            @unique @default(cuid())
  type   TransactionType
  status TransactionStatus @default(PENDING)

  amount Decimal @db.Decimal(18, 2)

  // For WITHDRAW and TRANSFER
  fromAccountId String?
  fromAccount   Account? @relation("FromAccountTransactions", fields: [fromAccountId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // For DEPOSIT and TRANSFER
  toAccountId String?
  toAccount   Account? @relation("ToAccountTransactions", fields: [toAccountId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Useful for optimistic concurrency / audit trail
  fromVersionBefore Int?
  toVersionBefore   Int?
  fromVersionAfter  Int?
  toVersionAfter    Int?

  fromBalanceBefore Decimal? @db.Decimal(18, 2)
  fromBalanceAfter  Decimal? @db.Decimal(18, 2)
  toBalanceBefore   Decimal? @db.Decimal(18, 2)
  toBalanceAfter    Decimal? @db.Decimal(18, 2)

  description   String?
  failureReason String?

  // Optional, but very useful to avoid duplicate transaction creation on retries
  idempotencyKey String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status, createdAt])
  @@index([fromAccountId, createdAt])
  @@index([toAccountId, createdAt])
}
